@page "/"
@using SoftwareVSM.Client.GameEngine
@using SoftwareVSM.Client.Services
@using SoftwareVSM.Client.Components
@inject SimulationEngine Engine
@inject SaveService SaveService
@implements IDisposable

@* ── Top metrics bar ── *@
<div class="top-bar">
    <h1>⬢ Software Factory</h1>
    <div class="metrics-panel">
        <div class="metric">
            <span class="metric-label">Funds</span>
            <span class="metric-value @(Engine.State.Funds >= 0 ? "positive" : "negative")">
                @Engine.State.Funds.ToString("C0")
            </span>
        </div>
        <div class="metric">
            <span class="metric-label">Satisfaction</span>
            <span class="metric-value @(Engine.State.CustomerSatisfaction > 0.7 ? "positive" : "negative")">
                @((Engine.State.CustomerSatisfaction * 100).ToString("0"))%
            </span>
        </div>
        <div class="metric">
            <span class="metric-label">Customers</span>
            <span class="metric-value">@Engine.State.CustomerCount.ToString("N0")</span>
        </div>
        <div class="metric">
            <span class="metric-label">Tech Debt</span>
            <span class="metric-value @(Engine.State.TechnicalDebt > 500 ? "negative" : "")">
                @Engine.State.TechnicalDebt.ToString("0")
            </span>
        </div>
        <div class="metric">
            <span class="metric-label">Revenue</span>
            <span class="metric-value positive">@Engine.State.TotalRevenue.ToString("C0")</span>
        </div>
    </div>
</div>

@* ── Game layout: toolbox + canvas ── *@
<div class="game-layout">
    <Toolbox />
    <GameCanvas />
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await SaveService.LoadAsync();
        Engine.Start();
    }

    public void Dispose()
    {
        Engine.Stop();
    }
}
