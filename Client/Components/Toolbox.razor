@using SoftwareVSM.Client.Models
@using SoftwareVSM.Client.Services
@inject CanvasDragService DragSvc

<div class="toolbox-panel">
    <div class="toolbox-section-label">Nodes — drag to canvas</div>

    @foreach (var entry in _nodes)
    {
        var type  = entry.Type;
        var color = entry.Color;
        <div class="toolbox-item"
             draggable="true"
             title="@entry.Description"
             @ondragstart="() => DragSvc.BeginToolboxDrag(type)"
             @ondragend="DragSvc.EndToolboxDrag">
            <div class="toolbox-dot" style="background:@color; color:@color"></div>
            <div class="toolbox-item-info">
                <span class="toolbox-item-name">@entry.Name</span>
                <span class="toolbox-item-ports">@entry.Ports</span>
            </div>
        </div>
    }

    <hr class="toolbox-divider" />
    <div class="toolbox-legend-title">Token colors</div>

    @foreach (var t in _tokens)
    {
        <div class="toolbox-token-row">
            <div class="toolbox-token-dot" style="background:@CanvasLayout.TokenColor(t.Type); box-shadow:0 0 4px @CanvasLayout.TokenColor(t.Type)"></div>
            <span>@t.Label</span>
        </div>
    }

    <hr class="toolbox-divider" />
    <div class="toolbox-legend-title">How to connect</div>
    <div style="font-size:0.62rem; color:#475569; padding:0.25rem 0.5rem; line-height:1.5;">
        Drag a <span style="color:#38bdf8">colored dot</span> on the <strong style="color:#94a3b8">right</strong> of a node to a matching dot on the <strong style="color:#94a3b8">left</strong> of another.<br/><br/>
        Click a connection line to delete it.
    </div>
</div>

@code {
    private readonly record struct NodeEntry(NodeType Type, string Name, string Ports, string Color, string Description);
    private readonly record struct TokenEntry(TokenType Type, string Label);

    private static readonly NodeEntry[] _nodes =
    [
        new(NodeType.CustomerDiscovery, "Customer Discovery", "→ Opportunity",              "#f59e0b", "Generates Opportunity from customer demand each tick."),
        new(NodeType.ProductManagement, "Product Mgmt",       "Opportunity → Feature",      "#3b82f6", "Converts market Opportunity into Features to build."),
        new(NodeType.Development,       "Development",        "Feature → Code",             "#10b981", "Builds Code from Features. Accepts Defect rework input."),
        new(NodeType.Quality,           "Quality",            "Code → ValidatedCode/Defect","#8b5cf6", "Validates Code; routes detected Defects back to Development."),
        new(NodeType.Operations,        "Operations",         "ValidatedCode → Running",    "#06b6d4", "Deploys ValidatedCode as RunningSoftware; surfaces Incidents."),
        new(NodeType.Support,           "Support",            "Incident → Defect/Opp.",     "#ec4899", "Routes Incidents back as Defects to dev and recovered Opportunity."),
    ];

    private static readonly TokenEntry[] _tokens =
    [
        new(TokenType.Opportunity,     "Opportunity"),
        new(TokenType.Feature,         "Feature"),
        new(TokenType.Code,            "Code"),
        new(TokenType.ValidatedCode,   "Validated Code"),
        new(TokenType.RunningSoftware, "Running Software"),
        new(TokenType.Defect,          "Defect"),
        new(TokenType.Incident,        "Incident"),
    ];
}
